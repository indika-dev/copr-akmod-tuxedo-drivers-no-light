# Diese Datei wird von akmods auf dem Zielrechner genutzt
%global modname tuxedo-drivers
%global buildforkernels akmod
%global debug_package %{nil}

Name:           tuxedo-drivers-no-light-kmod
Version:        4.13.1
Release:        1%{?dist}
Summary:        Kernel module for Tuxedo Drivers
License:        GPL-2.0-or-later
Source0:        %{modname}-%{version}.tar.gz
Source1:        tuxedo-drivers-no-light-kmod.spec

BuildRequires:  kernel-devel, make, gcc
BuildRequires: kmodtool
%{expand:%(kmodtool --target %{_target_cpu} --kmodname tuxedo-drivers %{?buildforkernels:--%{buildforkernels}} 2>/dev/null) }

%description
LKM for Tuxedo hardware.

%prep
%setup -q -c -T -a 0
cp %{SOURCE1} %{_specdir}/
cd %{modname}-%{version}
for kernel_version  in %{?kernel_versions} ; do
  cp -a src _kmod_build_${kernel_version%%___*}
done

%build
for kernel_version in %{?kernel_versions}; do
  make V=1 %{?_smp_mflags} -C /lib/modules/${kernel_version%%___*}/build M=${PWD}/%{modname}-%{version}/_kmod_build_${kernel_version%%___*} modules
done

%install
# 2. udev & hwdb Files (deine Logik)
mkdir -p %{buildroot}/usr/lib/udev/rules.d/
mkdir -p %{buildroot}/usr/lib/udev/hwdb.d/
mkdir -p %{buildroot}/etc/modules-load.d/

install -D -m 644 %{modname}-%{version}/tuxedo_keyboard.conf %{buildroot}/etc/modules-load.d/tuxedo_keyboard.conf
install -D -m 644 %{modname}-%{version}/99-infinityflex-touchpanel-toggle.rules %{buildroot}/usr/lib/udev/rules.d/
install -D -m 644 %{modname}-%{version}/99-z-tuxedo-systemd-fix.rules %{buildroot}/usr/lib/udev/rules.d/
install -D -m 644 %{modname}-%{version}/61-sensor-tuxedo.hwdb %{buildroot}/usr/lib/udev/hwdb.d/
install -D -m 644 %{modname}-%{version}/61-keyboard-tuxedo.hwdb %{buildroot}/usr/lib/udev/hwdb.d/

for kernel_version in %{?kernel_versions}; do
  mkdir -p %{buildroot}/lib/modules/${kernel_version%%___*}/extra/%{modname}-no-light/
  install -D -m 755 %{modname}-%{version}/_kmod_build_${kernel_version%%___*}/**/*.ko %{buildroot}/lib/modules/${kernel_version%%___*}/extra/%{modname}-no-light/
  install -D -m 755 %{modname}-%{version}/_kmod_build_${kernel_version%%___*}/*.ko %{buildroot}/lib/modules/${kernel_version%%___*}/extra/%{modname}-no-light/
  chmod a+x %{buildroot}/lib/modules/${kernel_version%%___*}/extra/%{modname}-no-light/*.ko
done
%{?akmod_install}

%files
# Die Dateiliste wird automatisch durch das kmodtool-Makro befüllt

%package common
Summary:  Common configuration files for Tuxedo drivers
Provides: %{name}-common = %{version}-%{release}
%description kmod-common
Contains udev rules and hwdb configurations.

%files common
/etc/modules-load.d/*.conf
/usr/lib/udev/rules.d/*.rules
/usr/lib/udev/hwdb.d/*.hwdb

