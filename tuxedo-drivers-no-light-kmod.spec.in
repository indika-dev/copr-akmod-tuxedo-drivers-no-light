# Diese Datei wird von akmods auf dem Zielrechner genutzt
%global buildforkernels akmod
%global debug_package %{nil}

Name:           tuxedo-drivers-kmod
Version:        4.13.1
Release:        1%{?dist}
Summary:        Kernel module for Tuxedo Drivers
License:        GPL-2.0-or-later

BuildRequires:  kernel-devel, make, gcc
%{expand:%(kmodtool --target %{_target_cpu} --kmodname tuxedo-drivers %{?buildforkernels:--%{buildforkernels}} 2>/dev/null) }

%description
LKM for Tuxedo hardware.

%prep
%setup -q -c -T -a 0
# Hier die Pfade anpassen, damit sie zum Entpacken des Tarballs passen
cd tuxedo-drivers-%{version}

%build
for kernel_version in %{?kernel_versions}; do
    make -C /lib/modules/${kernel_version%%___*}/build M=$PWD modules
done

%install
for kernel_version in %{?kernel_versions}; do
    for item in $$(find . -type d -name *.ko) ; do install $${item} -D -m 755 %{buildroot}/lib/modules/${kernel_version%%___*}/extra/tuxedo-drivers/ ; done
done
%{?akmod_install}

%files
%{modname}-%{version}.tar.gz
%{name}-kmod.spec
