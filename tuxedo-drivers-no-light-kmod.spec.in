# Diese Datei wird von akmods auf dem Zielrechner genutzt
%global modname tuxedo-drivers
%global buildforkernels akmod
%global debug_package %{nil}

Name:           tuxedo-drivers-no-light-kmod
Version:        4.13.1
Release:        1%{?dist}
Summary:        Kernel module for Tuxedo Drivers
License:        GPL-2.0-or-later

BuildRequires:  kernel-devel, make, gcc
%{expand:%(kmodtool --target %{_target_cpu} --kmodname tuxedo-drivers %{?buildforkernels:--%{buildforkernels}} 2>/dev/null) }

%description
LKM for Tuxedo hardware.

%prep
%setup -q -c -T -a 0
# Hier die Pfade anpassen, damit sie zum Entpacken des Tarballs passen
cd tuxedo-drivers-%{version}

%build
for kernel_version in %{?kernel_versions}; do
    make -C /lib/modules/${kernel_version%%___*}/build M=$PWD modules
done

%install
# 2. udev & hwdb Files (deine Logik)
mkdir -p %{buildroot}/usr/lib/udev/rules.d/
mkdir -p %{buildroot}/usr/lib/udev/hwdb.d/
mkdir -p %{buildroot}/etc/modules-load.d/

install -D -m 644 tuxedo_keyboard.conf %{buildroot}/etc/modules-load.d/tuxedo_keyboard.conf
install -D -m 644 99-infinityflex-touchpanel-toggle.rules %{buildroot}/usr/lib/udev/rules.d/
install -D -m 644 99-z-tuxedo-systemd-fix.rules %{buildroot}/usr/lib/udev/rules.d/
install -D -m 644 61-sensor-tuxedo.hwdb %{buildroot}/usr/lib/udev/hwdb.d/
install -D -m 644 61-keyboard-tuxedo.hwdb %{buildroot}/usr/lib/udev/hwdb.d/

for kernel_version in %{?kernel_versions}; do
    for item in $$(find . -type d -name *.ko) ; do install $${item} -D -m 755 %{buildroot}/lib/modules/${kernel_version%%___*}/extra/tuxedo-drivers/ ; done
done
%{?akmod_install}

%files
/%{_usrsrc}/akmods/%{modname}-%{version}
/%{_usrsrc}/akmods/%{name}.spec


%package common
Summary:  Common configuration files for Tuxedo drivers
%description common
Contains udev rules and hwdb configurations.

%files common
/etc/modules-load.d/*.conf
/usr/lib/udev/rules.d/*.rules
/usr/lib/udev/hwdb.d/*.hwdb

